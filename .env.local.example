# --- Supabase ---
# Supabase ダッシュボード → Project Settings → API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
# サーバー側専用(秘匿)。RLS をバイパスする処理(Cron など)で使用
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# --- Anthropic (Claude API) ---
# https://console.anthropic.com/
# テンプレ運用なら不要。残置ライブラリ (src/lib/anthropic.ts) を将来使う場合だけ設定。
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Gemini (AI ハイブリッド生成用) ---
# https://aistudio.google.com/ で発行 (Google アカウントだけで OK、クレカ登録不要)
# 1日 1500 リクエストまで無料。テンプレに {{ai_subject_hint}} / {{ai_opening}} を入れた
# 場合だけ Gemini を呼ぶので、未設定でもアプリは動く (テンプレのみで送信)。
GEMINI_API_KEY=

# --- Resend ---
# https://resend.com/api-keys
RESEND_API_KEY=re_...
# Resend dashboard で設定する webhook の署名検証用シークレット
RESEND_WEBHOOK_SECRET=whsec_...

# --- Vercel Cron 認証用 ---
# 任意のランダム文字列(32文字以上推奨)
CRON_SECRET=replace-with-strong-random-string

# --- App ---
# 本番URL(配信停止リンクのベースURL)。Vercel deploy 時に上書き
NEXT_PUBLIC_APP_URL=http://localhost:3000
